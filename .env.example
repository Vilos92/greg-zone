# Key used to authorize the cloudflared docker container.
COPYPARTY_CLOUDFLARED_TOKEN=hunter2

# Key used to authorize the tailscale docker container.
TAILSCALE_AUTH_KEY=hunter3
TAILSCALE_EXIT_NODE_AUTH_KEY=hunterexitnode3

# Password to access transmission remotely.
TRANSMISSION_PASSWORD=hunter4

# Password to access Grafana dashboards.
GRAFANA_PASSWORD=hunter5

# Hermes Agent dashboard login (Tailscale-only UI at http://greg-zone:9010).
# Model keys (Gemini, etc.) are configured in the Hermes GUI and persist under
# GregZone Vault/hermes — do not put those here.
HERMES_DASHBOARD_BASIC_AUTH_USERNAME=hunterhermes
HERMES_DASHBOARD_BASIC_AUTH_PASSWORD=hunterhermespass
HERMES_DASHBOARD_BASIC_AUTH_SECRET=hunterhermessecret

# Agent key for playit.
PLAYIT_SECRET_KEY=hunterplayit6

# Webhook URL for Jordania Minecraft server.
DISCORD_JORDANIA_WEBHOOK_URL=hunterjordania7

# Webhook URL for copyparty.
DISCORD_COPYPARTY_WEBHOOK_URL=huntercopyparty8

# Webhook URL for plex.
DISCORD_PLEX_WEBHOOK_URL=hunterplex9

# Webhook URL for nginx.
DISCORD_NGINX_WEBHOOK_URL=hunternginx10

# Webhook URL for infra.
DISCORD_INFRA_WEBHOOK_URL=hunterinfra11

# Secret for creating a symmetric encrypted value for request security (e.g. health check header authentication).
ALERT_MONITOR_SECRET=hunteralertmonitor12

# Secret for being able to make requests to https://theipapi.com for location services.
IP_API_ACCESS_KEY=hunteripapi13

# Password to access the infra redis instance.
INFRA_REDIS_PASSWORD=hunterredis14

# Fine-grained PAT for scriptlancer compose self-hosted runners (github-runner-*).
# Repo: Vilos92/scriptlancer. Permission: Administration (Read and write).
GITHUB_RUNNER_ACCESS_TOKEN=hunterrunner15
